<%- include("partials/header.ejs") %>
    <%- include("partials/sidebar.ejs") %>

        <div class="content pb-0">

            <div class="d-flex align-items-center justify-content-between gap-2 mb-4 flex-wrap">
                <div>
                    <h4 class="mb-1">Expense Tracker</h4>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0 p-0">
                            <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Expense Tracker</li>
                        </ol>
                    </nav>
                </div>
                <div class="gap-2 d-flex align-items-center flex-wrap">
                    <a href="/dashboard" class="btn btn-icon btn-outline-light shadow"><i class="ti ti-refresh"></i></a>
                </div>
            </div>

            <div class="row flex-fill">
                <div class="col-xl-9 d-flex">
                    <div class="row g-3 flex-fill">
                        <div class="col-lg-3 col-md-6 col-6 d-flex">
                            <div class="card growth-card flex-fill bg-soft-success border-0 shadow-none">
                                <div class="card-header text-center border-0 py-3">
                                    <div class="avatar rounded avatar-md bg-success">
                                        <i class="ti ti-cash-banknote fs-24 text-white"></i>
                                    </div>
                                </div>
                                <div class="card-body bg-white rounded border mb-1 p-3">
                                    <p class="mb-2 fs-13 fw-medium text-dark">Total Income</p>
                                    <div class="fs-28 text-dark fw-bold mb-3"><%= formatAmount(totalIncome) %></div>
                                    <div class="fs-13 fw-medium text-muted">This month: <%= formatAmount(currentMonthIncome) %></div>
                                    <div id="income-mini-chart" class="mt-3"></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-6 d-flex">
                            <div class="card growth-card flex-fill bg-soft-danger border-0 shadow-none">
                                <div class="card-header text-center border-0 py-3">
                                    <div class="avatar rounded avatar-md bg-danger">
                                        <i class="ti ti-credit-card-pay fs-24 text-white"></i>
                                    </div>
                                </div>
                                <div class="card-body bg-white rounded border mb-1 p-3">
                                    <p class="mb-2 fs-13 fw-medium text-dark">Total Expenses</p>
                                    <div class="fs-28 text-dark fw-bold mb-3"><%= formatAmount(totalExpense) %></div>
                                    <div class="fs-13 fw-medium text-muted">This month: <%= formatAmount(currentMonthExpense) %></div>
                                    <div id="expense-mini-chart" class="mt-3"></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-6 d-flex">
                            <div class="card growth-card flex-fill bg-purple-subtle border-0 shadow-none">
                                <div class="card-header text-center border-0 py-3">
                                    <div class="avatar rounded avatar-md bg-purple">
                                        <i class="ti ti-wallet fs-24 text-white"></i>
                                    </div>
                                </div>
                                <div class="card-body bg-white rounded border mb-1 p-3">
                                    <p class="mb-2 fs-13 fw-medium text-dark">Remaining Balance</p>
                                    <div class="fs-28 text-dark fw-bold mb-3"><%= formatAmount(currentBalance) %></div>
                                    <div class="fs-13 fw-medium text-muted"><%= walletCount %> wallets connected</div>
                                    <div id="balance-mini-chart" class="mt-3"></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-6 d-flex">
                            <div class="card growth-card flex-fill bg-soft-warning border-0 shadow-none">
                                <div class="card-header text-center border-0 py-3">
                                    <div class="avatar rounded avatar-md bg-warning">
                                        <i class="ti ti-chart-bar fs-24 text-white"></i>
                                    </div>
                                </div>
                                <div class="card-body bg-white rounded border mb-1 p-3">
                                    <p class="mb-2 fs-13 fw-medium text-dark">Savings Rate</p>
                                    <div class="fs-28 text-dark fw-bold mb-3"><%= savingsRate.toFixed(1) %>%</div>
                                    <div class="fs-13 fw-medium text-muted"><%= categoryCount %> categories tracked</div>
                                    <div id="savings-mini-chart" class="mt-3"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 d-flex">
                    <div class="card flex-fill dashboard-budget-card">
                        <div class="card-header d-flex align-items-center justify-content-between border-0">
                            <span class="fs-18 fw-bold text-dark">Budget Snapshot</span>
                            <a href="/budget" class="btn btn-sm btn-icon btn-outline-light"><i class="ti ti-chart-pie"></i></a>
                        </div>
                        <div class="card-body pt-0">
                            <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-2">
                                <div id="retained-chart" class="flex-grow-1"></div>
                                <div class="text-end budget-stat-copy">
                                    <div class="fs-24 text-dark fw-semibold mb-1 d-flex align-items-center gap-1">
                                        <%= budgetLeftPercent.toFixed(0) %>%
                                    </div>
                                    <p class="mb-0 fs-13 fw-medium">Budget Left</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between">
                                <div id="churned-chart" class="flex-grow-1"></div>
                                <div class="text-end budget-stat-copy">
                                    <div class="fs-24 text-dark fw-semibold mb-1 d-flex align-items-center gap-1">
                                        <%= budgetUsedPercent.toFixed(0) %>%
                                    </div>
                                    <p class="mb-0 fs-13 fw-medium">Budget Used</p>
                                </div>
                            </div>
                            <div class="mt-3 pt-1 budget-meta-note">
                                <small class="text-muted d-block">Active budget limit: <%= formatAmount(budgetTarget) %></small>
                                <small class="text-muted d-block"><%= budgetPeriodLabel %></small>
                                <small class="d-block mt-2 <%= budgetRemainingAmount >= 0 ? "text-success" : "text-danger fw-semibold" %>">
                                    <%= budgetRemainingAmount >= 0 ? "Budget left: " : "Over by: " %><%= formatAmount(Math.abs(budgetRemainingAmount)) %>
                                </small>
                            </div>

                            <% if (dashboardBudgetAlerts.length) { %>
                                <div class="mt-3 pt-3 border-top">
                                    <% dashboardBudgetAlerts.forEach((alert) => { %>
                                        <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                            <div class="min-w-0">
                                                <div class="fs-13 fw-semibold text-dark"><%= alert.title %></div>
                                                <small class="text-muted d-block"><%= alert.periodLabel %></small>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge <%= alert.remaining < 0 ? "bg-danger-subtle text-danger" : "bg-warning-subtle text-warning" %>"><%= alert.status %></span>
                                                <small class="d-block mt-1 <%= alert.remaining < 0 ? "text-danger" : "text-warning" %>">
                                                    <%= alert.remaining < 0 ? `-${formatAmount(Math.abs(alert.remaining))}` : `${alert.usedPercent.toFixed(0)}% used` %>
                                                </small>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 col-xl-6 d-flex">
                    <div class="card flex-fill">
                        <div class="card-body pb-0">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <div class="mb-0 fs-18 fw-bold text-dark">Monthly Cash Flow</div>
                                    <small class="text-muted">Expense against monthly earning capacity</small>
                                </div>
                                <span class="badge bg-light text-dark">Last 6 Months</span>
                            </div>
                            <div id="revenue-chart2"></div>
                        </div>
                    </div>
                </div>
                <div class="col-md-12 col-xl-6 d-flex">
                    <div class="card flex-fill">
                        <div class="card-body pb-0">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <div class="mb-0 fs-18 fw-bold text-dark">Expense Category Share</div>
                                    <small class="text-muted">
                                        <%= topCategory ? `${topCategory.category} leads with ${formatAmount(topCategory.amount)}` : "Add expense entries to unlock category insights" %>
                                    </small>
                                </div>
                                <span class="badge bg-light text-dark"><%= new Date().getFullYear() %></span>
                            </div>
                            <div id="region-wise-growth"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-xl-4 d-flex">
                    <div class="card flex-fill">
                        <div class="card-body">
                            <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                                <div>
                                    <div class="mb-0 fs-18 fw-bold text-dark">Reminder Pulse</div>
                                    <small class="text-muted">Quick view of your dues, tasks, and follow-ups</small>
                                </div>
                                <a href="/reminders" class="btn btn-sm btn-outline-light">Open</a>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <div class="border rounded p-3 h-100">
                                        <div class="text-muted fs-13 mb-1">Due Today</div>
                                        <div class="fs-24 fw-bold text-warning"><%= reminderSummary.dueToday %></div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="border rounded p-3 h-100">
                                        <div class="text-muted fs-13 mb-1">Overdue</div>
                                        <div class="fs-24 fw-bold text-danger"><%= reminderSummary.overdue %></div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="border rounded p-3 h-100">
                                        <div class="text-muted fs-13 mb-1">To Pay</div>
                                        <div class="fs-18 fw-bold text-dark"><%= formatAmount(reminderSummary.moneyToPay) %></div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="border rounded p-3 h-100">
                                        <div class="text-muted fs-13 mb-1">To Receive</div>
                                        <div class="fs-18 fw-bold text-dark"><%= formatAmount(reminderSummary.moneyToReceive) %></div>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <span class="text-muted fs-13">Urgency Ratio</span>
                                    <span class="fw-semibold"><%= reminderSummary.totalActive ? `${Math.round((reminderSummary.overdue / reminderSummary.totalActive) * 100)}%` : "0%" %></span>
                                </div>
                                <div class="progress progress-sm">
                                    <div
                                        class="progress-bar bg-danger js-reminder-pay-progress"
                                        role="progressbar"
                                        data-progress="<%= reminderPayProgress %>"
                                        aria-valuemin="0"
                                        aria-valuemax="100"
                                        aria-valuenow="<%= reminderPayProgress %>"
                                    ></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-8 d-flex">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                <div>
                                    <div class="mb-0 fs-18 fw-bold text-dark">Net Growth Trend</div>
                                    <small class="text-muted">
                                        <%= bestBalanceMonth ? `${bestBalanceMonth.label} had the strongest balance` : "Waiting for transaction history" %>
                                    </small>
                                </div>
                                <span class="badge bg-light text-dark">Last 6 Months</span>
                            </div>
                            <div id="growth-trend"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-xl-5 d-flex">
                    <div class="card flex-fill">
                        <div class="card-body pb-0">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <div class="mb-0 fs-18 fw-bold text-dark">Wallet Balance Overview</div>
                                    <small class="text-muted">
                                        <%= walletBalances.length ? `${walletBalances.length} active wallets tracked` : "Create wallets to compare balances" %>
                                    </small>
                                </div>
                                <span class="badge bg-light text-dark"><%= formatAmount(totalWalletBalance) %></span>
                            </div>
                            <div id="wallet-balance-overview"></div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-7 d-flex">
                    <div class="card flex-fill">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <div class="mb-0 fs-18 fw-bold text-dark">Upcoming Reminder Alerts</div>
                                    <small class="text-muted">
                                        <% if (reminderAlerts.length) { %>
                                            Most urgent upcoming items from Reminders &amp; Dues
                                        <% } else { %>
                                            Add reminders to surface alerts here
                                        <% } %>
                                    </small>
                                </div>
                                <a href="/reminders" class="btn btn-sm btn-outline-light">View All</a>
                            </div>

                            <% if (!reminderAlerts.length) { %>
                                <div class="text-center text-muted py-5">
                                    No reminder alerts yet. Create EMI, bill, borrowed, lent, or task reminders to populate this panel.
                                </div>
                            <% } %>

                            <% reminderAlerts.forEach((item) => { %>
                                <div class="d-flex align-items-center justify-content-between gap-3 border rounded p-3 mb-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="avatar avatar-md rounded-circle bg-<%= item.accentClass %>-subtle text-<%= item.accentClass %> d-inline-flex align-items-center justify-content-center">
                                            <i class="ti <%= item.category === "task" ? "ti-checklist" : item.category === "lent" ? "ti-cash-banknote" : item.category === "borrowed" ? "ti-credit-card-pay" : "ti-bell-ringing" %>"></i>
                                        </span>
                                        <div>
                                            <div class="fw-semibold text-dark"><%= item.title %></div>
                                            <div class="text-muted fs-13"><%= item.subtitle %></div>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div><span class="badge <%= reminderBadgeClass(item.lifecycleStatus) %>"><%= item.displayStatus %></span></div>
                                        <% if (item.amount > 0) { %>
                                            <div class="fw-semibold mt-2"><%= formatAmount(item.amount) %></div>
                                        <% } %>
                                    </div>
                                </div>
                            <% }) %>

                            <% if (upcomingTasks.length) { %>
                                <div class="pt-2 border-top mt-3">
                                    <div class="fw-semibold text-dark mb-3">Upcoming Tasks</div>
                                    <div class="row g-3">
                                        <% upcomingTasks.forEach((task) => { %>
                                            <div class="col-md-4">
                                                <div class="border rounded p-3 h-100">
                                                    <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                                                        <span class="badge <%= reminderPriorityClass(task.priority) %>"><%= task.priority %></span>
                                                        <span class="badge <%= reminderBadgeClass(task.lifecycleStatus) %>"><%= task.lifecycleStatus.replace("-", " ") %></span>
                                                    </div>
                                                    <div class="fw-semibold text-dark mb-1"><%= task.title %></div>
                                                    <small class="text-muted"><%= task.dueDateText %></small>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 d-flex">
                    <div class="card flex-fill">
                        <div class="card-body">
                            <div class="mb-4 fs-18 fw-bold text-dark">Monthly Expense Overview</div>

                            <div class="table-responsive custom-table table-nowrap">
                                <table class="table table-nowrap">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Period</th>
                                            <th>Income</th>
                                            <th>Expenses</th>
                                            <th>Balance</th>
                                            <th>Top Category</th>
                                            <th>Budget Used</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (!monthOverview.length) { %>
                                            <tr>
                                                <td colspan="7" class="text-center py-5 text-muted">
                                                    No transactions found yet. Add transactions to populate the dashboard.
                                                </td>
                                            </tr>
                                        <% } %>

                                        <% monthOverview.forEach((month) => { %>
                                            <% const hasBudgetTarget = Number(budgetTarget || 0) > 0; %>
                                            <% const rawBudgetPercent = hasBudgetTarget ? ((month.expense / budgetTarget) * 100) : 0; %>
                                            <% const budgetPercent = hasBudgetTarget ? Math.min(rawBudgetPercent, 100) : 0; %>
                                            <% const budgetStatus = !hasBudgetTarget ? "No Budget" : month.expense > budgetTarget ? "Over Budget" : rawBudgetPercent >= 80 ? "At Risk" : "On Track"; %>
                                            <% const budgetStatusClass = budgetStatus === "Over Budget" ? "bg-danger-subtle text-danger" : budgetStatus === "At Risk" ? "bg-warning-subtle text-warning" : budgetStatus === "On Track" ? "bg-success-subtle text-success" : "bg-light text-dark"; %>
                                            <tr>
                                                <td><%= month.label %></td>
                                                <td class="text-success"><%= formatAmount(month.income) %></td>
                                                <td class="text-danger"><%= formatAmount(month.expense) %></td>
                                                <td class="<%= month.balance >= 0 ? "text-primary" : "text-danger" %>"><%= formatAmount(month.balance) %></td>
                                                <td><%= month.topCategory %></td>
                                                <td><%= hasBudgetTarget ? `${budgetPercent.toFixed(0)}%` : "-" %></td>
                                                <td>
                                                    <span class="badge <%= budgetStatusClass %>">
                                                        <%= budgetStatus %>
                                                    </span>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

        </div>

        <script id="dashboard-chart-data" type="application/json">
            <%- JSON.stringify({
                ...chartData,
                budgetLeftPercent: Number(budgetLeftPercent.toFixed(0)),
                budgetUsedPercent: Number(budgetUsedPercent.toFixed(0)),
            }) %>
        </script>

        <script>
            document.querySelectorAll(".js-reminder-pay-progress").forEach((element) => {
                const value = Number(element.dataset.progress || 0);
                const boundedValue = Math.max(0, Math.min(100, value));
                element.style.width = `${boundedValue}%`;
            });
        </script>

        <%- include("partials/footer.ejs") %>
