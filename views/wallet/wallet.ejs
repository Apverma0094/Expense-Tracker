<%
function formatAmount(amount, currency = "INR") {
    const symbol = currency === "INR" ? "Rs. " : `${currency} `;
    return symbol + Number(amount || 0).toLocaleString("en-IN", {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
    });
}

function formatDate(dateValue) {
    const date = new Date(dateValue);

    if (Number.isNaN(date.getTime())) {
        return "-";
    }

    return date.toLocaleDateString("en-GB", {
        day: "2-digit",
        month: "short",
        year: "numeric",
    });
}

function formatInputDate(dateValue) {
    const date = new Date(dateValue);

    if (Number.isNaN(date.getTime())) {
        return "";
    }

    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const day = String(date.getDate()).padStart(2, "0");

    return `${year}-${month}-${day}`;
}
%>

<%- include("../partials/header.ejs") %>

    <%- include("../partials/sidebar.ejs") %>

        <style>
            .page-filter-shell {
                display: grid;
                grid-template-columns: minmax(0, 1fr) auto;
                align-items: center;
                gap: 16px;
            }

            .page-filter-left,
            .page-filter-group,
            .page-filter-actions {
                display: flex;
                align-items: center;
                gap: 10px;
                flex-wrap: wrap;
            }

            .page-filter-left {
                min-width: 0;
            }

            .page-filter-cta {
                display: flex;
                align-items: center;
                justify-content: flex-end;
                gap: 10px;
                flex-wrap: wrap;
            }

            .page-filter-field {
                width: 150px;
                min-width: 150px;
            }

            .page-filter-search {
                width: 220px;
            }

            @media (max-width: 767.98px) {
                .page-filter-shell,
                .page-filter-left,
                .page-filter-group,
                .page-filter-actions {
                    display: flex;
                    align-items: stretch;
                    grid-template-columns: none;
                    flex-wrap: wrap;
                }

                .page-filter-cta {
                    justify-content: stretch;
                }

                .page-filter-field,
                .page-filter-search,
                .page-filter-cta .btn {
                    width: 100%;
                    min-width: 100%;
                }
            }
        </style>

        <div class="content pb-0">

            <div class="d-flex align-items-center justify-content-between gap-2 mb-4 flex-wrap">
                <div>
                    <h4 class="mb-1">Wallets<span class="badge badge-soft-primary ms-2"><%= meta.totalWallets %></span></h4>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0 p-0">
                            <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Wallets</li>
                        </ol>
                    </nav>
                </div>
                <div class="gap-2 d-flex align-items-center flex-wrap">
                    <a href="/wallet" class="btn btn-icon btn-outline-light shadow" data-bs-toggle="tooltip"
                        data-bs-placement="top" aria-label="Refresh" data-bs-original-title="Refresh"><i
                            class="ti ti-refresh"></i></a>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body">
                            <p class="text-muted mb-2">Total Wallet Balance</p>
                            <h4 class="mb-0 text-primary"><%= formatAmount(meta.totalBalance) %></h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body">
                            <p class="text-muted mb-2">Active Wallets</p>
                            <h4 class="mb-0"><%= walletOptions.length %></h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 rounded-0">
                <div class="card-body">

                    <form action="/wallet" method="get" class="page-filter-shell mb-4">
                        <div class="page-filter-left">
                            <div class="page-filter-group">
                                <select class="form-select page-filter-field" name="type">
                                    <option value="">All Wallet Types</option>
                                    <option value="bank" <%= filters.type === "bank" ? "selected" : "" %>>Bank</option>
                                    <option value="cash" <%= filters.type === "cash" ? "selected" : "" %>>Cash</option>
                                    <option value="digital" <%= filters.type === "digital" ? "selected" : "" %>>Digital</option>
                                </select>

                                <select class="form-select page-filter-field" name="currency">
                                    <option value="">All Currencies</option>
                                    <% meta.currencies.forEach((currency) => { %>
                                        <option value="<%= currency %>" <%= filters.currency === currency ? "selected" : "" %>><%= currency %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="page-filter-actions">
                                <input type="text" class="form-control page-filter-search" name="search" value="<%= filters.search %>"
                                    placeholder="Search wallets...">
                                <button type="submit" class="btn btn-outline-light shadow">Filter</button>
                                <a href="/wallet" class="btn btn-outline-light shadow">Clear</a>
                            </div>
                        </div>

                        <div class="page-filter-cta">
                            <button type="button" class="btn btn-primary" data-bs-toggle="offcanvas"
                                data-bs-target="#addWallet">
                                + Add Wallet
                            </button>
                            <button type="button" class="btn btn-outline-light shadow" data-bs-toggle="offcanvas"
                                data-bs-target="#transferWallet">
                                <i class="ti ti-arrows-transfer-up-down me-2"></i>Transfer
                            </button>
                        </div>
                    </form>

                    <div class="table-responsive table-nowrap custom-table">
                        <table class="table table-nowrap" id="walletTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Wallet</th>
                                    <th>Type</th>
                                    <th>Balance</th>
                                    <th>Currency</th>
                                    <th>Transactions</th>
                                    <th>Transfers</th>
                                    <th class="no-sort">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!wallets.length) { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted">
                                            No wallets found. Add your first wallet to start tracking balances.
                                        </td>
                                    </tr>
                                <% } %>

                                <% wallets.forEach((wallet) => { %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="avatar avatar-sm rounded-circle <%= wallet.badgeClass %> border-0">
                                                    <i class="<%= wallet.iconClass %> fs-16"></i>
                                                </span>
                                                <%= wallet.name %>
                                            </div>
                                        </td>
                                        <td><span class="badge <%= wallet.badgeClass %>"><%= wallet.typeLabel %></span></td>
                                        <td><%= formatAmount(wallet.balance, wallet.currency) %></td>
                                        <td><span class="badge bg-light text-dark"><%= wallet.currency %></span></td>
                                        <td><%= wallet.transactionCount %></td>
                                        <td><%= wallet.transferCount %></td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-sm btn-light" data-bs-toggle="offcanvas"
                                                    data-bs-target="#walletView-<%= wallet._id %>">
                                                    <i class="ti ti-chart-bar"></i>
                                                </button>
                                                <button class="btn btn-sm btn-light" data-bs-toggle="offcanvas"
                                                    data-bs-target="#editWallet-<%= wallet._id %>">
                                                    <i class="ti ti-edit"></i>
                                                </button>
                                                <form action="/wallet/<%= wallet._id %>/delete" method="post" class="m-0">
                                                    <button class="btn btn-sm btn-light text-danger" type="submit"
                                                        onclick="return confirm('Delete this wallet?')">
                                                        <i class="ti ti-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>

        </div>

        <% wallets.forEach((wallet) => { %>
            <div class="offcanvas offcanvas-end" tabindex="-1" id="walletView-<%= wallet._id %>">
                <div class="offcanvas-header border-bottom">
                    <h5>Wallet Overview</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
                </div>
                <div class="offcanvas-body">
                    <div class="text-center mb-4">
                        <h4><%= wallet.name %></h4>
                        <span class="badge <%= wallet.badgeClass %>"><%= wallet.typeLabel %> Wallet</span>
                        <h3 class="mt-3"><%= formatAmount(wallet.balance, wallet.currency) %></h3>
                    </div>

                    <div class="mb-3"><strong>Currency:</strong> <%= wallet.currency %></div>
                    <div class="mb-3"><strong>Opening Balance:</strong> <%= formatAmount(wallet.openingBalance, wallet.currency) %></div>
                    <div class="mb-3"><strong>Total Transactions:</strong> <%= wallet.transactionCount %></div>
                    <div class="mb-3"><strong>Total Transfers:</strong> <%= wallet.transferCount %></div>
                    <div class="mb-3"><strong>Income Added:</strong> <%= formatAmount(wallet.totalIncome, wallet.currency) %></div>
                    <div class="mb-3"><strong>Expense Spent:</strong> <%= formatAmount(wallet.totalExpense, wallet.currency) %></div>
                    <div class="mb-3"><strong>Incoming Transfers:</strong> <%= formatAmount(wallet.incomingTransfers, wallet.currency) %></div>
                    <div class="mb-3"><strong>Outgoing Transfers:</strong> <%= formatAmount(wallet.outgoingTransfers, wallet.currency) %></div>
                    <div class="mb-3"><strong>Last Activity:</strong> <%= formatDate(wallet.lastActivity) %></div>
                    <div class="mb-4">
                        <strong>Notes:</strong>
                        <p class="mb-0"><%= wallet.notes || "No notes added." %></p>
                    </div>
                </div>
            </div>

            <div class="offcanvas offcanvas-end offcanvas-large" tabindex="-1" id="editWallet-<%= wallet._id %>">
                <div class="offcanvas-header border-bottom">
                    <div>
                        <h5 class="mb-0 fw-bold">Edit Wallet</h5>
                        <small class="text-muted">Update this wallet for your expense tracker</small>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
                </div>

                <div class="offcanvas-body">
                    <form action="/wallet/<%= wallet._id %>/update" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-medium">Wallet Name</label>
                            <input type="text" name="name" class="form-control" value="<%= wallet.name %>" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Type</label>
                                <select class="form-select" name="type" required>
                                    <option value="bank" <%= wallet.type === "bank" ? "selected" : "" %>>Bank</option>
                                    <option value="cash" <%= wallet.type === "cash" ? "selected" : "" %>>Cash</option>
                                    <option value="digital" <%= wallet.type === "digital" ? "selected" : "" %>>Digital</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Currency</label>
                                <select class="form-select" name="currency" required>
                                    <option value="INR" <%= wallet.currency === "INR" ? "selected" : "" %>>INR</option>
                                    <option value="USD" <%= wallet.currency === "USD" ? "selected" : "" %>>USD</option>
                                    <option value="EUR" <%= wallet.currency === "EUR" ? "selected" : "" %>>EUR</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Opening Balance</label>
                                <input type="number" step="0.01" min="0" name="openingBalance" class="form-control"
                                    value="<%= wallet.openingBalance %>" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Opening Date</label>
                                <input type="date" name="openingBalanceDate" class="form-control"
                                    value="<%= formatInputDate(wallet.openingBalanceDate) %>" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium">Note</label>
                            <textarea class="form-control" name="notes" rows="3"
                                placeholder="Add wallet purpose or extra details..."><%= wallet.notes || "" %></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-semibold">
                            <i class="ti ti-device-floppy me-2"></i>Update Wallet
                        </button>
                    </form>
                </div>
            </div>
        <% }) %>

        <div class="offcanvas offcanvas-end offcanvas-large" tabindex="-1" id="addWallet">
            <div class="offcanvas-header border-bottom">
                <div>
                    <h5 class="mb-0 fw-bold">Add Wallet</h5>
                    <small class="text-muted">Create a new wallet for your money tracking</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="offcanvas-body">
                <form action="/wallet/add" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Wallet Name</label>
                        <input type="text" name="name" class="form-control" placeholder="SBI, Cash Wallet, Paytm..." required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Type</label>
                            <select class="form-select" name="type" required>
                                <option selected disabled value="">Select Type</option>
                                <option value="bank">Bank</option>
                                <option value="cash">Cash</option>
                                <option value="digital">Digital</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Currency</label>
                            <select class="form-select" name="currency" required>
                                <option value="INR" selected>INR</option>
                                <option value="USD">USD</option>
                                <option value="EUR">EUR</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Opening Balance</label>
                            <input type="number" step="0.01" min="0" name="openingBalance" class="form-control"
                                placeholder="0.00" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Opening Date</label>
                            <input type="date" name="openingBalanceDate" class="form-control" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Note</label>
                        <textarea class="form-control" name="notes" rows="3"
                            placeholder="Add wallet purpose or extra details..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-semibold">
                        <i class="ti ti-device-floppy me-2"></i>Save Wallet
                    </button>
                </form>
            </div>
        </div>

        <div class="offcanvas offcanvas-end offcanvas-large" tabindex="-1" id="transferWallet">
            <div class="offcanvas-header border-bottom">
                <div>
                    <h5 class="mb-0 fw-bold">Transfer Between Wallets</h5>
                    <small class="text-muted">Move money from one wallet to another</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="offcanvas-body">
                <form action="/wallet/transfer" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">From Wallet</label>
                            <select class="form-select" name="fromWallet" required>
                                <option selected disabled value="">Select Wallet</option>
                                <% walletOptions.forEach((wallet) => { %>
                                    <option value="<%= wallet.name %>"><%= wallet.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">To Wallet</label>
                            <select class="form-select" name="toWallet" required>
                                <option selected disabled value="">Select Wallet</option>
                                <% walletOptions.forEach((wallet) => { %>
                                    <option value="<%= wallet.name %>"><%= wallet.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Amount</label>
                            <input type="number" step="0.01" min="0" name="amount" class="form-control"
                                placeholder="0.00" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Date</label>
                            <input type="date" name="transferDate" class="form-control" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Note</label>
                        <textarea class="form-control" name="note" rows="3" placeholder="Reason for transfer..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-semibold">
                        <i class="ti ti-arrows-transfer-up-down me-2"></i>Transfer Amount
                    </button>
                </form>
            </div>
        </div>

        <%- include("../partials/footer.ejs")%>
