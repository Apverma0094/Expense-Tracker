<%
function formatAmount(amount) {
    return "Rs. " + Number(amount || 0).toLocaleString("en-IN", {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
    });
}

function formatDate(dateValue) {
    const date = new Date(dateValue);

    if (Number.isNaN(date.getTime())) {
        return "-";
    }

    return date.toLocaleDateString("en-GB", {
        day: "2-digit",
        month: "short",
        year: "numeric",
    });
}

const categoryLabels = categoryBreakdown.map((item) => item.category);
const categoryValues = categoryBreakdown.map((item) => Number(item.amount || 0));
const monthLabels = monthlyOverview.map((item) => item.label);
const monthIncome = monthlyOverview.map((item) => Number(item.income || 0));
const monthExpense = monthlyOverview.map((item) => Number(item.expense || 0));
const monthBalance = monthlyOverview.map((item) => Number(item.balance || 0));
const monthlyTransactionSeries = monthlyTransactionCounts.map((item) => Number(item.count || 0));
const walletLabels = walletBalances.map((item) => item.name);
const walletValues = walletBalances.map((item) => Number(item.balance || 0));
const incomeExpenseSplit = [
    Number(meta.totalIncome || 0),
    Number(meta.totalExpense || 0),
];
const incomeExpenseSplitLabels = ["Income", "Expense"];
const topCategory = categoryBreakdown[0] || null;
const strongestMonth = monthlyOverview.reduce((best, month) => (
    !best || Number(month.balance || 0) > Number(best.balance || 0) ? month : best
), null);
const topExpenseMonths = [...monthlyOverview]
    .filter((item) => Number(item.expense || 0) > 0)
    .sort((a, b) => Number(b.expense || 0) - Number(a.expense || 0))
    .slice(0, 5);
const topExpenseMonthLabels = topExpenseMonths.map((item) => item.label);
const topExpenseMonthValues = topExpenseMonths.map((item) => Number(item.expense || 0));
const totalWalletBalance = walletValues.reduce((sum, value) => sum + value, 0);
%>

<%- include("../partials/header.ejs") %>

    <%- include("../partials/sidebar.ejs") %>

        <div class="content pb-0">

            <div class="d-flex align-items-center justify-content-between gap-2 mb-4 flex-wrap">
                <div>
                    <h4 class="mb-1">Analytics</h4>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0 p-0">
                            <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Analytics</li>
                        </ol>
                    </nav>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <form action="/analytics" method="get" class="d-flex align-items-center gap-2">
                        <select class="form-select" name="year">
                            <% meta.years.forEach((year) => { %>
                                <option value="<%= year %>" <%= filters.year === year ? "selected" : "" %>><%= year %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn btn-outline-light shadow">Filter</button>
                    </form>
                    <a href="/analytics" class="btn btn-icon btn-outline-light shadow"><i class="ti ti-refresh"></i></a>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6 col-xl-3 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body">
                            <p class="text-muted mb-2">Total Income</p>
                            <h4 class="mb-2 text-success"><%= formatAmount(meta.totalIncome) %></h4>
                            <small class="text-muted"><%= meta.transactionCount %> transactions in <%= filters.year %></small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body">
                            <p class="text-muted mb-2">Total Expense</p>
                            <h4 class="mb-2 text-danger"><%= formatAmount(meta.totalExpense) %></h4>
                            <small class="text-muted">Average expense: <%= formatAmount(meta.averageExpense) %></small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body">
                            <p class="text-muted mb-2">Net Balance</p>
                            <h4 class="mb-2 <%= meta.totalBalance >= 0 ? "text-primary" : "text-danger" %>"><%= formatAmount(meta.totalBalance) %></h4>
                            <small class="text-muted">Savings rate: <%= meta.savingsRate.toFixed(1) %>%</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body">
                            <p class="text-muted mb-2">Coverage</p>
                            <h4 class="mb-2"><%= meta.walletCount %> Wallets / <%= meta.categoryCount %> Categories</h4>
                            <small class="text-muted">Tracked structure for reports</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-xl-8 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body pb-0">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <h5 class="mb-1">Monthly Expense Overview</h5>
                                    <p class="text-muted mb-0">
                                        <%= strongestMonth ? `${strongestMonth.label} had the strongest net balance in ${filters.year}` : `Income and expense trend across ${filters.year}` %>
                                    </p>
                                </div>
                            </div>
                            <div id="monthly-overview-chart"></div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-4 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body pb-0">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <h5 class="mb-1">Wallet Balance Split</h5>
                                    <p class="text-muted mb-0">Current balance distribution across all wallets</p>
                                </div>
                                <span class="badge bg-light text-dark"><%= formatAmount(totalWalletBalance) %></span>
                            </div>
                            <div id="wallet-balance-chart"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-xl-5 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body pb-0">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <h5 class="mb-1">Spending By Categories</h5>
                                    <p class="text-muted mb-0">
                                        <%= topCategory ? `${topCategory.category} is the top spend category` : `Top expense categories for ${filters.year}` %>
                                    </p>
                                </div>
                            </div>
                            <div id="category-spend-chart"></div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body pb-0">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <h5 class="mb-1">Income vs Expense Split</h5>
                                    <p class="text-muted mb-0">Overall share for <%= filters.year %></p>
                                </div>
                            </div>
                            <div id="income-expense-split-chart"></div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-4 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body pb-0">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <h5 class="mb-1">Transaction Volume</h5>
                                    <p class="text-muted mb-0">Month-wise activity count</p>
                                </div>
                            </div>
                            <div id="transaction-volume-chart"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-xl-5 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body pb-0">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <h5 class="mb-1">Highest Expense Months</h5>
                                    <p class="text-muted mb-0">Months where spending peaked the most</p>
                                </div>
                            </div>
                            <div id="top-expense-months-chart"></div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-7 d-flex">
                    <div class="card flex-fill border-0 rounded-0">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <h5 class="mb-1">Recent Transactions</h5>
                                    <p class="text-muted mb-0">Latest activity across wallets and categories</p>
                                </div>
                            </div>
                            <div class="table-responsive table-nowrap custom-table">
                                <table class="table table-nowrap mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Title</th>
                                            <th>Category</th>
                                            <th>Wallet</th>
                                            <th>Type</th>
                                            <th>Amount</th>
                                            <th>Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (!recentTransactions.length) { %>
                                            <tr>
                                                <td colspan="6" class="text-center py-5 text-muted">
                                                    No transactions yet. Add transactions to unlock analytics.
                                                </td>
                                            </tr>
                                        <% } %>

                                        <% recentTransactions.forEach((transaction) => { %>
                                            <tr>
                                                <td><%= transaction.title %></td>
                                                <td><%= transaction.category %></td>
                                                <td><%= transaction.wallet %></td>
                                                <td>
                                                    <span class="badge <%= transaction.type === "income" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger" %>">
                                                        <%= transaction.type === "income" ? "Income" : "Expense" %>
                                                    </span>
                                                </td>
                                                <td><%= formatAmount(transaction.amount) %></td>
                                                <td><%= formatDate(transaction.transactionDate) %></td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-xl-12">
                    <div class="card border-0 rounded-0">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <h5 class="mb-1">Category Breakdown</h5>
                                    <p class="text-muted mb-0">Detailed expense totals by category</p>
                                </div>
                            </div>
                            <div class="table-responsive table-nowrap custom-table">
                                <table class="table table-nowrap mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Category</th>
                                            <th>Spent</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (!categoryBreakdown.length) { %>
                                            <tr>
                                                <td colspan="2" class="text-center py-5 text-muted">
                                                    No expense transactions found for <%= filters.year %>.
                                                </td>
                                            </tr>
                                        <% } %>

                                        <% categoryBreakdown.forEach((item) => { %>
                                            <tr>
                                                <td><%= item.category %></td>
                                                <td><%= formatAmount(item.amount) %></td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <script>
            (function () {
                const hasApex = typeof ApexCharts !== "undefined";
                if (!hasApex) {
                    return;
                }

                const textMuted = "#6c757d";
                const borderColor = "#e9ecef";

                const monthlyChartEl = document.querySelector("#monthly-overview-chart");
                if (monthlyChartEl) {
                    new ApexCharts(monthlyChartEl, {
                        chart: {
                            type: "line",
                            height: 320,
                            toolbar: { show: false }
                        },
                        series: [
                            { name: "Income", type: "column", data: <%- JSON.stringify(monthIncome) %> },
                            { name: "Expense", type: "column", data: <%- JSON.stringify(monthExpense) %> },
                            { name: "Balance", type: "line", data: <%- JSON.stringify(monthBalance) %> }
                        ],
                        colors: ["#198754", "#dc3545", "#0d6efd"],
                        plotOptions: {
                            bar: {
                                columnWidth: "42%",
                                borderRadius: 4
                            }
                        },
                        stroke: {
                            width: [0, 0, 3],
                            curve: "smooth"
                        },
                        dataLabels: { enabled: false },
                        xaxis: {
                            categories: <%- JSON.stringify(monthLabels) %>,
                            labels: { style: { colors: textMuted } },
                            axisBorder: { color: borderColor },
                            axisTicks: { color: borderColor }
                        },
                        yaxis: {
                            labels: {
                                style: { colors: textMuted },
                                formatter: (value) => "Rs. " + Number(value || 0).toLocaleString("en-IN")
                            }
                        },
                        grid: { borderColor },
                        legend: { position: "top" }
                    }).render();
                }

                const categoryChartEl = document.querySelector("#category-spend-chart");
                if (categoryChartEl) {
                    new ApexCharts(categoryChartEl, {
                        chart: {
                            type: "bar",
                            height: 320
                        },
                        series: [
                            { name: "Spent", data: <%- JSON.stringify(categoryValues.length ? categoryValues.slice(0, 6) : [0]) %> }
                        ],
                        colors: ["#dc3545", "#fd7e14", "#ffc107", "#20c997", "#0dcaf0", "#6f42c1", "#198754"],
                        plotOptions: {
                            bar: {
                                horizontal: true,
                                borderRadius: 6,
                                barHeight: "55%",
                                distributed: true
                            }
                        },
                        dataLabels: { enabled: false },
                        xaxis: {
                            categories: <%- JSON.stringify(categoryLabels.length ? categoryLabels.slice(0, 6) : ["No Data"]) %>,
                            labels: {
                                style: { colors: textMuted },
                                formatter: (value) => "Rs. " + Number(value || 0).toLocaleString("en-IN")
                            },
                            axisBorder: { color: borderColor },
                            axisTicks: { color: borderColor }
                        },
                        yaxis: {
                            labels: { style: { colors: textMuted } }
                        },
                        legend: { show: false },
                        grid: { borderColor },
                        tooltip: {
                            y: {
                                formatter: (value) => "Rs. " + Number(value || 0).toLocaleString("en-IN", {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                })
                            }
                        }
                    }).render();
                }

                const incomeExpenseSplitChartEl = document.querySelector("#income-expense-split-chart");
                if (incomeExpenseSplitChartEl) {
                    new ApexCharts(incomeExpenseSplitChartEl, {
                        chart: {
                            type: "pie",
                            height: 320
                        },
                        labels: <%- JSON.stringify(incomeExpenseSplitLabels) %>,
                        series: <%- JSON.stringify(incomeExpenseSplit.some((value) => value > 0) ? incomeExpenseSplit : [1, 1]) %>,
                        colors: ["#198754", "#dc3545"],
                        dataLabels: { enabled: true },
                        legend: { position: "bottom" },
                        tooltip: {
                            y: {
                                formatter: (value) => "Rs. " + Number(value || 0).toLocaleString("en-IN", {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                })
                            }
                        }
                    }).render();
                }

                const transactionVolumeChartEl = document.querySelector("#transaction-volume-chart");
                if (transactionVolumeChartEl) {
                    new ApexCharts(transactionVolumeChartEl, {
                        chart: {
                            type: "area",
                            height: 320,
                            toolbar: { show: false }
                        },
                        series: [
                            { name: "Transactions", data: <%- JSON.stringify(monthlyTransactionSeries) %> }
                        ],
                        colors: ["#0d6efd"],
                        dataLabels: { enabled: false },
                        stroke: { curve: "smooth", width: 3 },
                        fill: {
                            type: "gradient",
                            gradient: {
                                shadeIntensity: 0.4,
                                opacityFrom: 0.35,
                                opacityTo: 0.05
                            }
                        },
                        xaxis: {
                            categories: <%- JSON.stringify(monthLabels) %>,
                            labels: { style: { colors: textMuted } },
                            axisBorder: { color: borderColor },
                            axisTicks: { color: borderColor }
                        },
                        yaxis: {
                            min: 0,
                            forceNiceScale: true,
                            labels: {
                                style: { colors: textMuted },
                                formatter: (value) => Math.round(Number(value || 0))
                            }
                        },
                        grid: { borderColor },
                        legend: { position: "top" }
                    }).render();
                }

                const topExpenseMonthsChartEl = document.querySelector("#top-expense-months-chart");
                if (topExpenseMonthsChartEl) {
                    new ApexCharts(topExpenseMonthsChartEl, {
                        chart: {
                            type: "bar",
                            height: 320,
                            toolbar: { show: false }
                        },
                        series: [
                            { name: "Expense", data: <%- JSON.stringify(topExpenseMonthValues.length ? topExpenseMonthValues : [0]) %> }
                        ],
                        colors: ["#f97316"],
                        plotOptions: {
                            bar: {
                                borderRadius: 6,
                                columnWidth: "55%"
                            }
                        },
                        dataLabels: { enabled: false },
                        xaxis: {
                            categories: <%- JSON.stringify(topExpenseMonthLabels.length ? topExpenseMonthLabels : ["No Data"]) %>,
                            labels: { style: { colors: textMuted } },
                            axisBorder: { color: borderColor },
                            axisTicks: { color: borderColor }
                        },
                        yaxis: {
                            labels: {
                                style: { colors: textMuted },
                                formatter: (value) => "Rs. " + Number(value || 0).toLocaleString("en-IN")
                            }
                        },
                        tooltip: {
                            y: {
                                formatter: (value) => "Rs. " + Number(value || 0).toLocaleString("en-IN", {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                })
                            }
                        },
                        grid: { borderColor },
                        legend: { show: false }
                    }).render();
                }

                const walletChartEl = document.querySelector("#wallet-balance-chart");
                if (walletChartEl) {
                    new ApexCharts(walletChartEl, {
                        chart: {
                            type: "donut",
                            height: 320
                        },
                        labels: <%- JSON.stringify(walletLabels.length ? walletLabels : ["No Wallets"]) %>,
                        series: <%- JSON.stringify(walletValues.length ? walletValues : [1]) %>,
                        colors: ["#0d6efd", "#198754", "#fd7e14", "#6f42c1", "#0dcaf0"],
                        dataLabels: { enabled: false },
                        legend: { position: "bottom" },
                        tooltip: {
                            y: {
                                formatter: (value) => "Rs. " + Number(value || 0).toLocaleString("en-IN", {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                })
                            }
                        }
                    }).render();
                }
            }());
        </script>

        <%- include("../partials/footer.ejs")%>
