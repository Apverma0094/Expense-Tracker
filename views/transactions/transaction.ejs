        <% }) %>

        <div class="offcanvas offcanvas-end offcanvas-large" tabindex="-1" id="addTransaction">
            <div class="offcanvas-header border-bottom">
                <div>
                    <h5 class="mb-0 fw-bold">Add Transaction</h5>
