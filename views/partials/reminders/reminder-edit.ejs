<div class="modal fade" id="editReminder-<%= reminder._id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <form action="/reminders/<%= reminder._id %>/update" method="post">
                <div class="modal-header">
                    <div>
                        <h5 class="mb-1">Edit <%= reminder.categoryLabel %> Reminder</h5>
                        <small class="text-muted">Keep the reminder current without leaving the page.</small>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <% if (reminder.category === "emi" || reminder.category === "bill") { %>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Reminder Type</label>
                                <select class="form-select" name="category">
                                    <option value="emi" <%= reminder.category === "emi" ? "selected" : "" %>>EMI</option>
                                    <option value="bill" <%= reminder.category === "bill" ? "selected" : "" %>>Bill</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Title</label>
                                <input type="text" name="title" class="form-control" value="<%= reminder.title %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Amount</label>
                                <input type="number" name="amount" class="form-control" step="0.01" min="0" value="<%= reminder.amount %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Due Date</label>
                                <input type="date" name="dueDate" class="form-control" value="<%= reminder.dueDateInput %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Repeat Type</label>
                                <select class="form-select" name="repeatType">
                                    <option value="none" <%= reminder.repeatType === "none" ? "selected" : "" %>>None</option>
                                    <option value="monthly" <%= reminder.repeatType === "monthly" ? "selected" : "" %>>Monthly</option>
                                    <option value="quarterly" <%= reminder.repeatType === "quarterly" ? "selected" : "" %>>Quarterly</option>
                                    <option value="yearly" <%= reminder.repeatType === "yearly" ? "selected" : "" %>>Yearly</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Reminder Before</label>
                                <select class="form-select" name="reminderBefore">
                                    <option value="0" <%= Number(reminder.reminderBefore) === 0 ? "selected" : "" %>>Same Day</option>
                                    <option value="1" <%= Number(reminder.reminderBefore) === 1 ? "selected" : "" %>>1 Day</option>
                                    <option value="3" <%= Number(reminder.reminderBefore) === 3 ? "selected" : "" %>>3 Days</option>
                                    <option value="7" <%= Number(reminder.reminderBefore) === 7 ? "selected" : "" %>>7 Days</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Payment Wallet</label>
                                <select class="form-select" name="wallet" required>
                                    <option value="">Select Wallet</option>
                                    <% walletOptions.forEach((wallet) => { %>
                                        <option value="<%= wallet.name %>" <%= reminder.wallet === wallet.name ? "selected" : "" %>><%= wallet.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3 d-flex align-items-end">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" name="notificationEnabled" <%= reminder.notificationEnabled ? "checked" : "" %>>
                                    <label class="form-check-label">Notification Enabled</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">Notes</label>
                                <textarea name="notes" class="form-control" rows="3"><%= reminder.notes || "" %></textarea>
                            </div>
                        </div>
                    <% } %>

                    <% if (reminder.category === "borrowed") { %>
                        <input type="hidden" name="category" value="borrowed">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Person Name</label>
                                <input type="text" name="personName" class="form-control" value="<%= reminder.personName %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Amount</label>
                                <input type="number" name="amount" class="form-control" step="0.01" min="0" value="<%= reminder.amount %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Borrow Date</label>
                                <input type="date" name="borrowDate" class="form-control" value="<%= reminder.borrowDateInput %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Return Date</label>
                                <input type="date" name="returnDate" class="form-control" value="<%= reminder.dueDateInput %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Reminder Before</label>
                                <select class="form-select" name="reminderBefore">
                                    <option value="0" <%= Number(reminder.reminderBefore) === 0 ? "selected" : "" %>>Same Day</option>
                                    <option value="1" <%= Number(reminder.reminderBefore) === 1 ? "selected" : "" %>>1 Day</option>
                                    <option value="3" <%= Number(reminder.reminderBefore) === 3 ? "selected" : "" %>>3 Days</option>
                                    <option value="7" <%= Number(reminder.reminderBefore) === 7 ? "selected" : "" %>>7 Days</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3 d-flex align-items-end">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" name="notificationEnabled" <%= reminder.notificationEnabled ? "checked" : "" %>>
                                    <label class="form-check-label">Notification Enabled</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">Notes</label>
                                <textarea name="notes" class="form-control" rows="3"><%= reminder.notes || "" %></textarea>
                            </div>
                        </div>
                    <% } %>

                    <% if (reminder.category === "lent") { %>
                        <input type="hidden" name="category" value="lent">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Person Name</label>
                                <input type="text" name="personName" class="form-control" value="<%= reminder.personName %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Amount</label>
                                <input type="number" name="amount" class="form-control" step="0.01" min="0" value="<%= reminder.amount %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Given Date</label>
                                <input type="date" name="givenDate" class="form-control" value="<%= reminder.givenDateInput %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Expected Return Date</label>
                                <input type="date" name="expectedReturnDate" class="form-control" value="<%= reminder.dueDateInput %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Reminder Before</label>
                                <select class="form-select" name="reminderBefore">
                                    <option value="0" <%= Number(reminder.reminderBefore) === 0 ? "selected" : "" %>>Same Day</option>
                                    <option value="1" <%= Number(reminder.reminderBefore) === 1 ? "selected" : "" %>>1 Day</option>
                                    <option value="3" <%= Number(reminder.reminderBefore) === 3 ? "selected" : "" %>>3 Days</option>
                                    <option value="7" <%= Number(reminder.reminderBefore) === 7 ? "selected" : "" %>>7 Days</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3 d-flex align-items-end">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" name="notificationEnabled" <%= reminder.notificationEnabled ? "checked" : "" %>>
                                    <label class="form-check-label">Notification Enabled</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">Notes</label>
                                <textarea name="notes" class="form-control" rows="3"><%= reminder.notes || "" %></textarea>
                            </div>
                        </div>
                    <% } %>

                    <% if (reminder.category === "task") { %>
                        <input type="hidden" name="category" value="task">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Title</label>
                                <input type="text" name="title" class="form-control" value="<%= reminder.title %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Due Date</label>
                                <input type="date" name="dueDate" class="form-control" value="<%= reminder.dueDateInput %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Priority</label>
                                <select class="form-select" name="priority">
                                    <option value="high" <%= reminder.priority === "high" ? "selected" : "" %>>High</option>
                                    <option value="medium" <%= reminder.priority === "medium" ? "selected" : "" %>>Medium</option>
                                    <option value="low" <%= reminder.priority === "low" ? "selected" : "" %>>Low</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Reminder Before</label>
                                <select class="form-select" name="reminderBefore">
                                    <option value="0" <%= Number(reminder.reminderBefore) === 0 ? "selected" : "" %>>Same Day</option>
                                    <option value="1" <%= Number(reminder.reminderBefore) === 1 ? "selected" : "" %>>1 Day</option>
                                    <option value="3" <%= Number(reminder.reminderBefore) === 3 ? "selected" : "" %>>3 Days</option>
                                    <option value="7" <%= Number(reminder.reminderBefore) === 7 ? "selected" : "" %>>7 Days</option>
                                </select>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label fw-medium">Description</label>
                                <textarea name="description" class="form-control" rows="3"><%= reminder.notes || "" %></textarea>
                            </div>
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="notificationEnabled" <%= reminder.notificationEnabled ? "checked" : "" %>>
                                    <label class="form-check-label">Notification Enabled</label>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Reminder</button>
                </div>
            </form>
        </div>
    </div>
</div>
