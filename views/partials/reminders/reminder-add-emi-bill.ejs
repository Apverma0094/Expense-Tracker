<div class="modal fade" id="addEmiBillModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <form action="/reminders/add" method="post">
                <div class="modal-header">
                    <div>
                        <h5 class="mb-1">Add EMI / Bill Reminder</h5>
                        <small class="text-muted">Recurring bills and EMIs can auto-create expenses when marked paid.</small>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Reminder Type</label>
                            <select class="form-select" name="category">
                                <option value="emi">EMI</option>
                                <option value="bill">Bill</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Title</label>
                            <input type="text" name="title" class="form-control" placeholder="Bike EMI, Electricity Bill..." required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Amount</label>
                            <input type="number" name="amount" class="form-control" step="0.01" min="0" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Due Date</label>
                            <input type="date" name="dueDate" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Repeat Type</label>
                            <select class="form-select" name="repeatType">
                                <option value="none">None</option>
                                <option value="monthly">Monthly</option>
                                <option value="quarterly">Quarterly</option>
                                <option value="yearly">Yearly</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Reminder Before</label>
                            <select class="form-select" name="reminderBefore">
                                <option value="0">Same Day</option>
                                <option value="1" selected>1 Day</option>
                                <option value="3">3 Days</option>
                                <option value="7">7 Days</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Payment Wallet</label>
                            <select class="form-select" name="wallet" <%= hasWallets ? "required" : "disabled" %>>
                                <option value="">Select Wallet</option>
                                <% walletOptions.forEach((wallet) => { %>
                                    <option value="<%= wallet.name %>" <%= defaultWallet === wallet.name ? "selected" : "" %>><%= wallet.name %></option>
                                <% }) %>
                            </select>
                            <% if (!hasWallets) { %>
                                <small class="text-danger">Create a wallet first so paid reminders can post into expenses.</small>
                            <% } %>
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" name="notificationEnabled" checked>
                                <label class="form-check-label">Notification Enabled</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium">Notes</label>
                            <textarea name="notes" class="form-control" rows="3" placeholder="Renewal details, account number, provider, or billing notes..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Reminder</button>
                </div>
            </form>
        </div>
    </div>
</div>
