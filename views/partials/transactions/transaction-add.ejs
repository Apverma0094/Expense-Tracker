<div
    class="offcanvas offcanvas-end offcanvas-large <%= addTransactionState ? 'show' : '' %>"
    tabindex="-1"
    id="addTransaction"
    <%= addTransactionState ? 'data-open-on-load="true" aria-modal="true" role="dialog" style="visibility: visible;"' : "" %>>
    <div class="offcanvas-header border-bottom">
        <div>
            <h5 class="mb-0 fw-bold">Add Transaction</h5>
            <small class="text-muted">Track your income and expenses</small>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <div class="offcanvas-body">
        <form action="/transactions/add" method="post" class="transaction-bill-form" data-add-transaction-form>
            <div
                class="alert alert-danger <%= addTransactionState?.errorMessage ? '' : 'd-none' %>"
                role="alert"
                data-add-transaction-error>
                <%= addTransactionState?.errorMessage || "" %>
            </div>
            <div class="mb-3">
                <label class="form-label fw-medium">Amount</label>
                <input
                    type="number"
                    step="0.01"
                    min="0"
                    name="amount"
                    class="form-control"
                    placeholder="0.00"
                    value="<%= addTransactionState?.values?.amount ?? '' %>"
                    required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-medium">Title</label>
                <input
                    type="text"
                    name="title"
                    class="form-control"
                    placeholder="Pizza Hut, Salary, Petrol Pump..."
                    value="<%= addTransactionState?.values?.title || '' %>"
                    required>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-medium">Wallet</label>
                    <select class="form-select" name="wallet" required>
                        <option <%= !addTransactionState?.values?.wallet ? "selected" : "" %> disabled value="">Select Wallet</option>
                        <% walletOptions.forEach((wallet) => { %>
                            <option value="<%= wallet.name %>" <%= addTransactionState?.values?.wallet === wallet.name ? "selected" : "" %>><%= wallet.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-medium">Type</label>
                    <select class="form-select" name="type" required data-transaction-type>
                        <option <%= !addTransactionState?.values?.type ? "selected" : "" %> disabled value="">Select Type</option>
                        <option value="expense" <%= addTransactionState?.values?.type === "expense" ? "selected" : "" %>>Expense</option>
                        <option value="income" <%= addTransactionState?.values?.type === "income" ? "selected" : "" %>>Income</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-medium">Category</label>
                    <select class="form-select category-select-compact-wide" name="category" required data-transaction-category>
                        <option selected disabled value="">Select Type First</option>
                        <% categoryOptions.forEach((category) => { %>
                            <option
                                value="<%= category.name %>"
                                data-type="<%= category.type %>"
                                <%= addTransactionState?.values?.category === category.name ? "selected" : "" %>>
                                <%= category.optionLabel %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-medium">Date</label>
                    <input
                        type="date"
                        name="transactionDate"
                        class="form-control"
                        value="<%= addTransactionState?.values?.transactionDate ? formatInputDate(addTransactionState.values.transactionDate) : '' %>"
                        required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-medium">Note</label>
                <textarea class="form-control" name="description" rows="3" placeholder="Add a note..."><%= addTransactionState?.values?.description || "" %></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-medium">Bill Image</label>
                <input
                    type="file"
                    class="form-control"
                    accept="image/png,image/jpeg,image/jpg,image/webp,image/gif"
                    data-bill-file
                >
                <small class="text-muted">Upload JPG, PNG, WEBP, or GIF up to 5MB.</small>
                <input type="hidden" name="billImageData" value="<%= addTransactionState?.values?.billImageData || '' %>" data-bill-data>
                <input type="hidden" name="billImageName" value="<%= addTransactionState?.values?.billImageName || '' %>" data-bill-name>
                <input type="hidden" name="billImageMime" value="<%= addTransactionState?.values?.billImageMime || '' %>" data-bill-mime>
            </div>

            <div class="mb-3" data-bill-preview-wrapper>
                <div class="border rounded p-3 text-muted text-center" data-bill-empty-state>
                    No bill image selected
                </div>
                <img
                    src=""
                    alt="Bill preview"
                    class="img-fluid rounded border mb-2 d-none"
                    style="max-height: 220px; object-fit: contain;"
                    data-bill-preview
                >
                <a href="#" class="btn btn-sm btn-outline-primary d-none" data-bill-download>
                    <i class="ti ti-download me-1"></i>Download Selected Bill
                </a>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3 fw-semibold">
                <i class="ti ti-device-floppy me-2"></i>Save Transaction
            </button>
        </form>
    </div>
</div>
