<div class="offcanvas offcanvas-end offcanvas-large" tabindex="-1" id="editTransaction-<%= transaction._id %>">
    <div class="offcanvas-header border-bottom">
        <div>
            <h5 class="mb-0 fw-bold">Edit Transaction</h5>
            <small class="text-muted">Update your income and expense record</small>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <div class="offcanvas-body">
        <form action="/transactions/<%= transaction._id %>/update" method="post" class="transaction-bill-form">
            <div class="mb-3">
                <label class="form-label fw-medium">Amount</label>
                <input type="number" step="0.01" min="0" name="amount" class="form-control"
                    value="<%= transaction.amount %>" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-medium">Title</label>
                <input type="text" name="title" class="form-control" value="<%= transaction.title %>" required>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-medium">Wallet</label>
                    <select class="form-select" name="wallet" required>
                        <option value="<%= transaction.wallet %>" selected><%= transaction.wallet %></option>
                        <% walletOptions.forEach((wallet) => { %>
                            <% if (wallet.name !== transaction.wallet) { %>
                                <option value="<%= wallet.name %>"><%= wallet.name %></option>
                            <% } %>
                        <% }) %>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-medium">Type</label>
                    <select class="form-select" name="type" required data-transaction-type>
                        <option value="expense" <%= transaction.type === "expense" ? "selected" : "" %>>Expense</option>
                        <option value="income" <%= transaction.type === "income" ? "selected" : "" %>>Income</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-medium">Category</label>
                    <select class="form-select category-select-compact-wide" name="category" required data-transaction-category data-selected-category="<%= transaction.category %>">
                        <option selected disabled value="">Select Category</option>
                        <% categoryOptions.forEach((category) => { %>
                            <option
                                value="<%= category.name %>"
                                data-type="<%= category.type %>"
                                <%= category.name === transaction.category ? "selected" : "" %>>
                                <%= category.optionLabel %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-medium">Date</label>
                    <input type="date" name="transactionDate" class="form-control"
                        value="<%= formatInputDate(transaction.transactionDate) %>" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-medium">Note</label>
                <textarea class="form-control" name="description" rows="3"
                    placeholder="Add a note..."><%= transaction.description || "" %></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-medium">Bill Image</label>
                <input
                    type="file"
                    class="form-control"
                    accept="image/png,image/jpeg,image/jpg,image/webp,image/gif"
                    data-bill-file
                >
                <small class="text-muted">Upload JPG, PNG, WEBP, or GIF up to 5MB.</small>
                <input type="hidden" name="billImageData" value="<%= transaction.billImageData || "" %>" data-bill-data>
                <input type="hidden" name="billImageName" value="<%= transaction.billImageName || "" %>" data-bill-name>
                <input type="hidden" name="billImageMime" value="<%= transaction.billImageMime || "" %>" data-bill-mime>
            </div>

            <div class="mb-3" data-bill-preview-wrapper>
                <% if (transaction.billImageData) { %>
                    <img
                        src="<%= transaction.billImageData %>"
                        alt="Bill preview"
                        class="img-fluid rounded border mb-2"
                        style="max-height: 220px; object-fit: contain;"
                        data-bill-preview
                    >
                    <a
                        href="<%= transaction.billImageData %>"
                        download="<%= formatDownloadName(transaction) %>"
                        class="btn btn-sm btn-outline-primary"
                        data-bill-download
                    >
                        <i class="ti ti-download me-1"></i>Download Current Bill
                    </a>
                <% } else { %>
                    <div class="border rounded p-3 text-muted text-center" data-bill-empty-state>
                        No bill image selected
                    </div>
                    <img
                        src=""
                        alt="Bill preview"
                        class="img-fluid rounded border mb-2 d-none"
                        style="max-height: 220px; object-fit: contain;"
                        data-bill-preview
                    >
                    <a href="#" class="btn btn-sm btn-outline-primary d-none" data-bill-download>
                        <i class="ti ti-download me-1"></i>Download Current Bill
                    </a>
                <% } %>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3 fw-semibold">
                <i class="ti ti-device-floppy me-2"></i>Update Transaction
            </button>
        </form>
    </div>
</div>
