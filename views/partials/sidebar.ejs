<!--=========================
                  Sidenav Menu Start 
             ============================-->
<%
function isSidebarRouteActive(route) {
    const path = currentPath || "/";

    return path === route || path.startsWith(`${route}/`);
}

function sidebarLinkStyle(isActive) {
    return isActive
        ? "background: var(--danger-transparent); border-radius: 6px; color: var(--primary);"
        : "";
}

function sidebarIconStyle(isActive) {
    return isActive
        ? "color: #fff; background-color: var(--primary);"
        : "";
}

function sidebarTextStyle(isActive) {
    return isActive
        ? "color: var(--primary);"
        : "";
}

const dashboardActive = isSidebarRouteActive("/dashboard");
const transactionsActive = isSidebarRouteActive("/transactions");
const categoriesActive = isSidebarRouteActive("/categories");
const analyticsActive = isSidebarRouteActive("/analytics");
const walletActive = isSidebarRouteActive("/wallet");
const remindersActive = isSidebarRouteActive("/reminders");
const budgetActive = isSidebarRouteActive("/budget");
const settingsActive = isSidebarRouteActive("/settings");
%>
<div class="sidebar" id="sidebar">

    <!-- Start Logo -->
    <div class="sidebar-logo">
        <div>
            <!-- Logo Normal -->
            <a href="/dashboard" class="logo logo-normal">
                <img src="assets/img/logo.svg" alt="Logo">
            </a>

            <!-- Logo Small -->
            <a href="/dashboard" class="logo-small">
                <img src="assets/img/logo-small.svg" alt="Logo">
            </a>

            <!-- Logo Dark -->
            <a href="/dashboard" class="dark-logo">
                <img src="assets/img/logo-white.svg" alt="Logo">
            </a>
        </div>
        <button class="sidenav-toggle-btn btn border-0 p-0 active" id="toggle_btn">
            <i class="ti ti-arrow-bar-to-left"></i>
        </button>

        <!-- Sidebar Menu Close -->
        <button class="sidebar-close">
            <i class="ti ti-x align-middle"></i>
        </button>
    </div>
    <!-- End Logo -->

    <!-- Sidenav Menu -->
    <div class="sidebar-inner" data-simplebar>
        <div id="sidebar-menu" class="sidebar-menu">
            <ul>
                <li class="menu-title"><span>Main Menu</span></li>
                <li>
                    <ul>
                        <li class="<%= dashboardActive ? 'active menu-item-current' : '' %>">
                            <a href="/dashboard" class="<%= dashboardActive ? 'active menu-link-current' : '' %>" style="<%= sidebarLinkStyle(dashboardActive) %>">
                                <i class="ti ti-layout-dashboard" style="<%= sidebarIconStyle(dashboardActive) %>"></i><span style="<%= sidebarTextStyle(dashboardActive) %>">Dashboard</span>
                            </a>
                        </li>
                        <li class="<%= transactionsActive ? 'active menu-item-current' : '' %>">
                            <a href="/transactions" class="<%= transactionsActive ? 'active menu-link-current' : '' %>" style="<%= sidebarLinkStyle(transactionsActive) %>"><i class="ti ti-receipt-2" style="<%= sidebarIconStyle(transactionsActive) %>"></i><span style="<%= sidebarTextStyle(transactionsActive) %>">Transactions</span>
                            </a>
                        </li>
                        <li class="<%= categoriesActive ? 'active menu-item-current' : '' %>">
                            <a href="/categories" class="<%= categoriesActive ? 'active menu-link-current' : '' %>" style="<%= sidebarLinkStyle(categoriesActive) %>">
                                <i class="ti ti-tags" style="<%= sidebarIconStyle(categoriesActive) %>"></i><span style="<%= sidebarTextStyle(categoriesActive) %>">Categories</span>
                            </a>
                        </li>

                        <li class="<%= analyticsActive ? 'active menu-item-current' : '' %>">
                            <a href="/analytics" class="<%= analyticsActive ? 'active menu-link-current' : '' %>" style="<%= sidebarLinkStyle(analyticsActive) %>">
                                <i class="ti ti-chart-histogram" style="<%= sidebarIconStyle(analyticsActive) %>"></i><span style="<%= sidebarTextStyle(analyticsActive) %>">Analytics</span>
                            </a>
                        </li>
                        <li class="<%= walletActive ? 'active menu-item-current' : '' %>">
                            <a href="/wallet" class="<%= walletActive ? 'active menu-link-current' : '' %>" style="<%= sidebarLinkStyle(walletActive) %>">
                                <i class="ti ti-wallet" style="<%= sidebarIconStyle(walletActive) %>"></i><span style="<%= sidebarTextStyle(walletActive) %>">Wallets</span>
                            </a>
                        </li>
                        <li class="<%= remindersActive ? 'active menu-item-current' : '' %>">
                            <a href="/reminders" class="<%= remindersActive ? 'active menu-link-current' : '' %>" style="<%= sidebarLinkStyle(remindersActive) %>">
                                <i class="ti ti-bell-ringing" style="<%= sidebarIconStyle(remindersActive) %>"></i><span style="<%= sidebarTextStyle(remindersActive) %>">Reminders & Dues</span>
                            </a>
                        </li>
                        <li class="<%= budgetActive ? 'active menu-item-current' : '' %>">
                            <a href="/budget" class="<%= budgetActive ? 'active menu-link-current' : '' %>" style="<%= sidebarLinkStyle(budgetActive) %>">
                                <i class="ti ti-chart-donut-3" style="<%= sidebarIconStyle(budgetActive) %>"></i><span style="<%= sidebarTextStyle(budgetActive) %>">Budget</span>
                            </a>
                        </li>
                        <li class="<%= settingsActive ? 'active menu-item-current' : '' %>">
                            <a href="/settings" class="<%= settingsActive ? 'active menu-link-current' : '' %>" style="<%= sidebarLinkStyle(settingsActive) %>">
                                <i class="ti ti-settings" style="<%= sidebarIconStyle(settingsActive) %>"></i><span style="<%= sidebarTextStyle(settingsActive) %>">Settings</span>
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>

</div>
<!-- Sidenav Menu End -->
