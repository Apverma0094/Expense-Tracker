<%
const profileImage = settings.profile.profileImage || "";
const profileDisplayName = settings.profile.fullName || user.email || "Expense Tracker Profile";
const profileInitials = profileDisplayName
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() || "")
    .join("") || "ET";
const budgetStatus = settings.notifications.budgetAlert ? "On" : "Off";
const walletStatus = settings.preferences.defaultWallet || "Not selected";
const budgetLimitValue = Number(settings.preferences.monthlyBudgetLimit || 0);
%>

<%- include("../partials/header.ejs") %>

<%- include("../partials/sidebar.ejs") %>

<style>
    .profile-settings-page {
        --settings-bg: linear-gradient(180deg, #f6f8fc 0%, #eef3f9 100%);
        --settings-surface: rgba(255, 255, 255, 0.92);
        --settings-border: rgba(15, 23, 42, 0.08);
        --settings-shadow: 0 22px 55px rgba(15, 23, 42, 0.08);
        --settings-primary: #0f766e;
        --settings-primary-soft: rgba(15, 118, 110, 0.12);
        --settings-text: #0f172a;
        --settings-muted: #64748b;
        background: var(--settings-bg);
    }

    .profile-settings-page .settings-shell {
        display: grid;
        grid-template-columns: minmax(300px, 360px) minmax(0, 1fr);
        gap: 24px;
    }

    .profile-settings-page .settings-panel,
    .profile-settings-page .settings-card {
        background: var(--settings-surface);
        border: 1px solid var(--settings-border);
        border-radius: 28px;
        box-shadow: var(--settings-shadow);
    }

    .profile-settings-page .settings-panel {
        position: sticky;
        top: 90px;
        overflow: hidden;
    }

    .profile-settings-page .profile-cover {
        padding: 28px 28px 18px;
        background:
            radial-gradient(circle at top right, rgba(14, 165, 233, 0.22), transparent 38%),
            linear-gradient(135deg, #0f766e 0%, #155e75 100%);
        color: #fff;
    }

    .profile-settings-page .profile-avatar {
        width: 88px;
        height: 88px;
        border-radius: 24px;
        overflow: hidden;
        border: 4px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.16);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.7rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        backdrop-filter: blur(12px);
    }

    .profile-settings-page .profile-meta {
        padding: 24px 28px 28px;
    }

    .profile-settings-page .mini-stat-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 24px;
    }

    .profile-settings-page .mini-stat {
        padding: 14px 16px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid rgba(148, 163, 184, 0.16);
    }

    .profile-settings-page .mini-stat-label {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--settings-muted);
        margin-bottom: 6px;
    }

    .profile-settings-page .mini-stat-value {
        color: var(--settings-text);
        font-weight: 700;
    }

    .profile-settings-page .hero-card {
        padding: 28px;
        margin-bottom: 24px;
        background:
            radial-gradient(circle at top left, rgba(15, 118, 110, 0.14), transparent 36%),
            linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(241, 245, 249, 0.92));
    }

    .profile-settings-page .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-radius: 999px;
        background: var(--settings-primary-soft);
        color: var(--settings-primary);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .profile-settings-page .settings-card {
        padding: 28px;
        margin-bottom: 24px;
    }

    .profile-settings-page .section-head {
        margin-bottom: 22px;
    }

    .profile-settings-page .section-head h5 {
        color: var(--settings-text);
        margin-bottom: 6px;
    }

    .profile-settings-page .section-head p,
    .profile-settings-page .subtle-note,
    .profile-settings-page .security-note {
        color: var(--settings-muted);
    }

    .profile-settings-page .form-label {
        font-size: 0.92rem;
        color: var(--settings-text);
    }

    .profile-settings-page .form-control,
    .profile-settings-page .form-select {
        min-height: 52px;
        border-radius: 16px;
        border-color: rgba(148, 163, 184, 0.28);
        background: rgba(255, 255, 255, 0.95);
        box-shadow: none;
    }

    .profile-settings-page .form-control:focus,
    .profile-settings-page .form-select:focus {
        border-color: rgba(15, 118, 110, 0.45);
        box-shadow: 0 0 0 0.2rem rgba(15, 118, 110, 0.12);
    }

    .profile-settings-page .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 20px;
        border-radius: 20px;
        border: 1px solid rgba(148, 163, 184, 0.16);
        background: #f8fafc;
    }

    .profile-settings-page .toggle-row + .toggle-row {
        margin-top: 14px;
    }

    .profile-settings-page .toggle-row h6 {
        margin-bottom: 4px;
        color: var(--settings-text);
    }

    .profile-settings-page .form-check-input {
        width: 3rem;
        height: 1.6rem;
        cursor: pointer;
    }

    .profile-settings-page .settings-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 20px 24px;
        border-radius: 22px;
        background: rgba(15, 23, 42, 0.04);
    }

    .profile-settings-page .settings-footer .btn {
        min-width: 170px;
        min-height: 50px;
        border-radius: 16px;
    }

    .profile-settings-page .security-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 20px;
        border-radius: 20px;
        border: 1px solid rgba(148, 163, 184, 0.16);
        background: linear-gradient(135deg, rgba(240, 253, 250, 0.95), rgba(248, 250, 252, 0.9));
    }

    .profile-settings-page .security-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 9px 14px;
        border-radius: 999px;
        background: rgba(22, 163, 74, 0.12);
        color: #15803d;
        font-weight: 700;
        white-space: nowrap;
    }

    @media (max-width: 1199.98px) {
        .profile-settings-page .settings-shell {
            grid-template-columns: 1fr;
        }

        .profile-settings-page .settings-panel {
            position: static;
        }
    }

    @media (max-width: 767.98px) {
        .profile-settings-page .hero-card,
        .profile-settings-page .settings-card,
        .profile-settings-page .profile-cover,
        .profile-settings-page .profile-meta {
            padding: 22px;
        }

        .profile-settings-page .mini-stat-grid {
            grid-template-columns: 1fr;
        }

        .profile-settings-page .settings-footer,
        .profile-settings-page .security-card,
        .profile-settings-page .toggle-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .profile-settings-page .settings-footer .btn {
            width: 100%;
        }
    }
</style>

<div class="content pb-4 profile-settings-page">
    <div class="hero-card settings-card">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
            <div>
                <span class="eyebrow">
                    <i class="ti ti-sparkles"></i>
                    Profile settings
                </span>
                <h2 class="mt-3 mb-2">Keep your account clean, personal, and ready to track money better.</h2>
                <p class="mb-0 subtle-note">Update only the settings that actually affect your daily expense workflow. Everything else has been trimmed away.</p>
            </div>
            <button class="btn btn-primary" type="submit" form="settingsForm">
                <i class="ti ti-device-floppy me-2"></i>Save Changes
            </button>
        </div>
    </div>

    <form id="settingsForm" action="/settings/update" method="post">
        <div class="settings-shell">
            <aside class="settings-panel">
                <div class="profile-cover">
                    <div class="profile-avatar">
                        <% if (profileImage) { %>
                            <img src="<%= profileImage %>" alt="Profile image" class="w-100 h-100 object-fit-cover">
                        <% } else { %>
                            <span><%= profileInitials %></span>
                        <% } %>
                    </div>
                    <h4 class="mt-3 mb-1 text-white"><%= profileDisplayName %></h4>
                    <p class="mb-0 text-white-50"><%= user.email || "Expense Tracker User" %></p>
                </div>

                <div class="profile-meta">
                    <p class="subtle-note mb-0">Your profile preview updates from the details below. Keep it simple and focused on the essentials.</p>

                    <div class="mini-stat-grid">
                        <div class="mini-stat">
                            <div class="mini-stat-label">Currency</div>
                            <div class="mini-stat-value"><%= settings.preferences.defaultCurrency %></div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-stat-label">Budget alert</div>
                            <div class="mini-stat-value"><%= budgetStatus %></div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-stat-label">Default wallet</div>
                            <div class="mini-stat-value"><%= walletStatus %></div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-stat-label">Monthly limit</div>
                            <div class="mini-stat-value"><%= budgetLimitValue > 0 ? `${settings.preferences.defaultCurrency} ${budgetLimitValue}` : "Not set" %></div>
                        </div>
                    </div>
                </div>
            </aside>

            <div>
                <div class="settings-card">
                    <div class="section-head">
                        <h5>Personal information</h5>
                        <p class="mb-0">These details shape how your profile appears inside the app.</p>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Full Name</label>
                            <input type="text" name="fullName" class="form-control" value="<%= settings.profile.fullName %>" placeholder="Enter your full name">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Email Address</label>
                            <input type="email" class="form-control" value="<%= user.email || "" %>" readonly>
                            <small class="subtle-note">Email is managed through your OTP login flow.</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Phone Number</label>
                            <input type="text" name="phone" class="form-control" value="<%= settings.profile.phone %>" placeholder="Enter phone number">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Profile Image URL</label>
                            <input type="url" name="profileImage" class="form-control" value="<%= settings.profile.profileImage %>" placeholder="https://example.com/avatar.jpg">
                            <small class="subtle-note">Use any public image link for your profile photo.</small>
                        </div>
                        <div class="col-md-6 mb-0">
                            <label class="form-label fw-medium">Preferred Timezone</label>
                            <select class="form-select" name="timezone">
                                <option value="Asia/Kolkata" <%= settings.profile.timezone === "Asia/Kolkata" ? "selected" : "" %>>Asia/Kolkata</option>
                                <option value="UTC" <%= settings.profile.timezone === "UTC" ? "selected" : "" %>>UTC</option>
                                <option value="Europe/London" <%= settings.profile.timezone === "Europe/London" ? "selected" : "" %>>Europe/London</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="settings-card">
                    <div class="section-head">
                        <h5>Expense preferences</h5>
                        <p class="mb-0">Set the defaults you want the tracker to use every day.</p>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Default Currency</label>
                            <select class="form-select" name="defaultCurrency">
                                <option value="INR" <%= settings.preferences.defaultCurrency === "INR" ? "selected" : "" %>>INR</option>
                                <option value="USD" <%= settings.preferences.defaultCurrency === "USD" ? "selected" : "" %>>USD</option>
                                <option value="EUR" <%= settings.preferences.defaultCurrency === "EUR" ? "selected" : "" %>>EUR</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Date Format</label>
                            <select class="form-select" name="dateFormat">
                                <option value="DD/MM/YYYY" <%= settings.preferences.dateFormat === "DD/MM/YYYY" ? "selected" : "" %>>DD/MM/YYYY</option>
                                <option value="MM/DD/YYYY" <%= settings.preferences.dateFormat === "MM/DD/YYYY" ? "selected" : "" %>>MM/DD/YYYY</option>
                                <option value="DD MMM YYYY" <%= settings.preferences.dateFormat === "DD MMM YYYY" ? "selected" : "" %>>DD MMM YYYY</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Month Starts On</label>
                            <select class="form-select" name="monthStart">
                                <option value="1" <%= settings.preferences.monthStart === "1" ? "selected" : "" %>>1st Day</option>
                                <option value="5" <%= settings.preferences.monthStart === "5" ? "selected" : "" %>>5th Day</option>
                                <option value="10" <%= settings.preferences.monthStart === "10" ? "selected" : "" %>>10th Day</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Default Wallet</label>
                            <select class="form-select" name="defaultWallet">
                                <option value="">Select Wallet</option>
                                <% wallets.forEach((wallet) => { %>
                                    <option value="<%= wallet.name %>" <%= settings.preferences.defaultWallet === wallet.name ? "selected" : "" %>><%= wallet.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-12 mb-0">
                            <label class="form-label fw-medium">Monthly Budget Limit</label>
                            <input type="number" step="0.01" min="0" name="monthlyBudgetLimit" class="form-control" value="<%= settings.preferences.monthlyBudgetLimit %>" placeholder="50000">
                        </div>
                    </div>
                </div>

                <div class="settings-card">
                    <div class="section-head">
                        <h5>Notifications</h5>
                        <p class="mb-0">Only the useful reminders are kept here, so this section stays actionable.</p>
                    </div>

                    <div class="toggle-row">
                        <div>
                            <h6>Budget limit alert</h6>
                            <p class="mb-0 subtle-note">Notify when spending reaches 80% of your budget.</p>
                        </div>
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input" type="checkbox" name="budgetAlert" <%= settings.notifications.budgetAlert ? "checked" : "" %>>
                        </div>
                    </div>

                    <div class="toggle-row">
                        <div>
                            <h6>Bill reminder</h6>
                            <p class="mb-0 subtle-note">Keep recurring payment reminders active.</p>
                        </div>
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input" type="checkbox" name="billReminder" <%= settings.notifications.billReminder ? "checked" : "" %>>
                        </div>
                    </div>

                    <div class="toggle-row">
                        <div>
                            <h6>Weekly summary</h6>
                            <p class="mb-0 subtle-note">Receive a short summary of income and expenses.</p>
                        </div>
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input" type="checkbox" name="weeklySummary" <%= settings.notifications.weeklySummary ? "checked" : "" %>>
                        </div>
                    </div>
                </div>

                <div class="settings-card">
                    <div class="section-head">
                        <h5>Account security</h5>
                        <p class="mb-0">Your login stays protected by the current OTP-based verification flow.</p>
                    </div>

                    <div class="security-card">
                        <div>
                            <h6 class="mb-1">Signed in with verified email</h6>
                            <p class="mb-1 security-note"><%= user.email || "Not available" %></p>
                            <p class="mb-0 security-note">Last profile update:
                                <%= user.updatedAt ? new Date(user.updatedAt).toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" }) : "No updates yet" %>
                            </p>
                        </div>
                        <span class="security-badge">
                            <i class="ti ti-shield-check"></i>
                            OTP protected
                        </span>
                    </div>
                </div>

                <div class="settings-footer">
                    <div>
                        <h6 class="mb-1">Ready to save?</h6>
                        <p class="mb-0 subtle-note">Your updated profile and preference settings will be applied immediately.</p>
                    </div>
                    <button class="btn btn-primary" type="submit">
                        <i class="ti ti-device-floppy me-2"></i>Save Changes
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<%- include("../partials/footer.ejs")%>
