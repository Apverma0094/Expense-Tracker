<%
function formatAmount(amount) {
    return "Rs. " + Number(amount || 0).toLocaleString("en-IN", {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
    });
}

function activeTabClass(tabKey) {
    return filters.tab === tabKey ? "active" : "";
}

function actionLabel(reminder) {
    if (reminder.category === "borrowed") {
        return "Mark Returned";
    }

    if (reminder.category === "lent") {
        return "Mark Received";
    }

    if (reminder.category === "task") {
        return "Mark Complete";
    }

    return "Mark as Paid";
}

function actionPath(reminder) {
    if (reminder.category === "borrowed") {
        return `/reminders/${reminder._id}/mark-returned`;
    }

    if (reminder.category === "lent") {
        return `/reminders/${reminder._id}/mark-received`;
    }

    if (reminder.category === "task") {
        return `/reminders/${reminder._id}/mark-complete`;
    }

    return `/reminders/${reminder._id}/mark-paid`;
}

function dueLabel(reminder) {
    if (reminder.category === "borrowed") {
        return "Return Date";
    }

    if (reminder.category === "lent") {
        return "Expected Return";
    }

    return "Due Date";
}

function buildDateDetails(reminder) {
    if (reminder.category === "borrowed") {
        return `Borrowed ${reminder.borrowDateInput || "-"} | Return ${reminder.dueDateInput || "-"}`;
    }

    if (reminder.category === "lent") {
        return `Given ${reminder.givenDateInput || "-"} | Return ${reminder.dueDateInput || "-"}`;
    }

    return reminder.dueDateText;
}

const dayNames = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
const calendarEventsJson = JSON.stringify(calendar.eventsByDate);
const selectedDateLabelText = selectedDateKey
    ? new Date(`${selectedDateKey}T12:00:00`).toLocaleDateString("en-GB", {
        day: "2-digit",
        month: "long",
        year: "numeric",
    })
    : "No scheduled reminders";
const tabMeta = [
    { key: "emi-bills", label: "EMI & Bills", count: tabs.emiBills.length },
    { key: "borrowed", label: "Borrowed Money", count: tabs.borrowed.length },
    { key: "lent", label: "Lent Money", count: tabs.lent.length },
    { key: "tasks", label: "Personal Tasks", count: tabs.tasks.length },
];
%>

<%- include("../partials/header.ejs") %>
<%- include("../partials/sidebar.ejs") %>

<style>
    .reminders-page .summary-hero {
        border-radius: 24px;
        background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
        color: #fff;
        overflow: hidden;
        position: relative;
    }

    .reminders-page .summary-hero::after {
        content: "";
        position: absolute;
        inset: auto -40px -50px auto;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
    }

    .reminders-page .quick-actions .btn {
        min-width: 132px;
    }

    .reminders-page .summary-card {
        border: 0;
        border-radius: 22px;
        overflow: hidden;
    }

    .reminders-page .summary-card .card-body {
        padding: 22px;
    }

    @media (min-width: 1200px) {
        .reminders-page .col-xl-2-4 {
            flex: 0 0 auto;
            width: 20%;
        }
    }

    .reminders-page .summary-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .reminders-page .calendar-card,
    .reminders-page .tab-card {
        border-radius: 24px;
        border: 0;
    }

    .reminders-page .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 10px;
    }

    .reminders-page .calendar-weekday {
        font-size: 0.85rem;
        color: #6b7280;
        font-weight: 600;
        text-align: center;
        padding-bottom: 4px;
    }

    .reminders-page .calendar-cell {
        min-height: 96px;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background: #fff;
        padding: 12px;
        cursor: pointer;
        transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
    }

    .reminders-page .calendar-cell:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 32px rgba(15, 23, 42, 0.08);
        border-color: rgba(37, 99, 235, 0.28);
    }

    .reminders-page .calendar-cell.empty {
        background: rgba(241, 245, 249, 0.55);
        cursor: default;
        border-style: dashed;
    }

    .reminders-page .calendar-cell.is-today {
        border-color: rgba(37, 99, 235, 0.4);
        box-shadow: inset 0 0 0 1px rgba(37, 99, 235, 0.2);
    }

    .reminders-page .calendar-cell.active-date {
        background: linear-gradient(180deg, rgba(219, 234, 254, 0.55), #fff);
        border-color: rgba(37, 99, 235, 0.45);
    }

    .reminders-page .calendar-date-number {
        font-weight: 700;
        color: #0f172a;
    }

    .reminders-page .calendar-dots {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 18px;
    }

    .reminders-page .calendar-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
    }

    .reminders-page .dot-emi {
        background: #ef4444;
    }

    .reminders-page .dot-money {
        background: #f97316;
    }

    .reminders-page .dot-task {
        background: #2563eb;
    }

    .reminders-page .dot-completed {
        background: #16a34a;
    }

    .reminders-page .day-events-panel {
        border-radius: 22px;
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.95), rgba(255, 255, 255, 0.98));
        border: 1px solid rgba(148, 163, 184, 0.18);
        min-height: 100%;
    }

    .reminders-page .event-item {
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        padding: 14px 16px;
        background: #fff;
    }

    .reminders-page .tab-pill {
        border-radius: 999px;
        padding: 7px 12px;
        font-weight: 600;
        color: #334155;
        font-size: 0.88rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
    }

    .reminders-page .tab-pill.active {
        background: #0d6efd;
        color: #fff;
    }

    .reminders-page .filter-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.94), #fff);
    }

    .reminders-page .filter-grid {
        display: grid;
        grid-template-columns: minmax(220px, 1.4fr) repeat(4, minmax(120px, 0.9fr));
        gap: 10px;
    }

    .reminders-page .filter-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-left: auto;
    }

    .reminders-page .filter-field-compact .form-label {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .reminders-page .tab-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .reminders-page .tab-nav {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-left: auto;
    }

    .reminders-page .section-kicker {
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #94a3b8;
    }

    .reminders-page .table-responsive td,
    .reminders-page .table-responsive th {
        vertical-align: middle;
    }

    .reminders-page .person-chip {
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .reminders-page .person-avatar {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        background: rgba(37, 99, 235, 0.12);
        color: #1d4ed8;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    .reminders-page .legend {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
    }

    .reminders-page .legend span {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #64748b;
        font-size: 0.9rem;
    }

    .reminders-page .legend i {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    @media (max-width: 991.98px) {
        .reminders-page .quick-actions .btn {
            min-width: auto;
        }

        .reminders-page .filter-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .reminders-page .filter-actions {
            margin-left: 0;
        }
    }

    @media (max-width: 767.98px) {
        .reminders-page .calendar-grid {
            gap: 8px;
        }

        .reminders-page .calendar-cell {
            min-height: 78px;
            padding: 10px;
        }

        .reminders-page .filter-grid {
            grid-template-columns: 1fr;
        }

        .reminders-page .filter-shell {
            grid-template-columns: 1fr;
        }

        .reminders-page .filter-actions,
        .reminders-page .tab-nav {
            width: 100%;
            margin-left: 0;
        }

        .reminders-page .filter-shell {
            padding: 16px;
        }
    }
</style>

<div class="content pb-0 reminders-page">
    <div class="d-flex align-items-center justify-content-between gap-3 mb-4 flex-wrap">
        <div>
            <h4 class="mb-1">Reminders & Dues</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Reminders & Dues</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap quick-actions">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addEmiBillModal">+ EMI/Bill</button>
            <button type="button" class="btn btn-outline-light shadow" data-bs-toggle="modal" data-bs-target="#addBorrowedModal">+ Borrowed</button>
            <button type="button" class="btn btn-outline-light shadow" data-bs-toggle="modal" data-bs-target="#addLentModal">+ Lent</button>
            <button type="button" class="btn btn-outline-light shadow" data-bs-toggle="modal" data-bs-target="#addTaskModal">+ Task</button>
        </div>
    </div>

    <div class="card summary-hero border-0 mb-4">
        <div class="card-body p-4 p-lg-5 position-relative">
            <div class="row align-items-center g-4">
                <div class="col-lg-7">
                    <span class="badge bg-white text-primary mb-3">Track bills, dues, tasks, and recoveries in one place</span>
                    <h2 class="mb-2 text-white">Stay ahead of upcoming payments, overdue amounts, and personal deadlines.</h2>
                    <p class="mb-0 text-white-50">EMIs, bills, borrowed money, lent money, and personal tasks now live in a single reminder workspace that matches the rest of your expense tracker.</p>
                </div>
                <div class="col-lg-5">
                    <div class="legend justify-content-lg-end">
                        <span><i class="dot-emi"></i>EMI/Bill</span>
                        <span><i class="dot-money"></i>Borrowed/Lent</span>
                        <span><i class="dot-task"></i>Task</span>
                        <span><i class="dot-completed"></i>Completed</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-2-4 d-flex">
            <div class="card summary-card flex-fill">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="summary-icon bg-primary-subtle text-primary"><i class="ti ti-bell-ringing"></i></span>
                        <span class="badge bg-light text-dark">Live</span>
                    </div>
                    <p class="text-muted mb-2">Total Active Reminders</p>
                    <h4 class="mb-0"><%= summary.totalActive %></h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-2-4 d-flex">
            <div class="card summary-card flex-fill">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="summary-icon bg-warning-subtle text-warning"><i class="ti ti-calendar-due"></i></span>
                        <span class="badge bg-warning-subtle text-warning">Today</span>
                    </div>
                    <p class="text-muted mb-2">Due Today</p>
                    <h4 class="mb-0"><%= summary.dueToday %></h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-2-4 d-flex">
            <div class="card summary-card flex-fill">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="summary-icon bg-danger-subtle text-danger"><i class="ti ti-alert-triangle"></i></span>
                        <span class="badge bg-danger-subtle text-danger">Attention</span>
                    </div>
                    <p class="text-muted mb-2">Overdue</p>
                    <h4 class="mb-0"><%= summary.overdue %></h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-2-4 d-flex">
            <div class="card summary-card flex-fill">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="summary-icon bg-danger-subtle text-danger"><i class="ti ti-credit-card-pay"></i></span>
                        <span class="badge bg-light text-dark">Payable</span>
                    </div>
                    <p class="text-muted mb-2">Money To Pay</p>
                    <h4 class="mb-0"><%= formatAmount(summary.moneyToPay) %></h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-2-4 d-flex">
            <div class="card summary-card flex-fill">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="summary-icon bg-success-subtle text-success"><i class="ti ti-cash-banknote"></i></span>
                        <span class="badge bg-light text-dark">Receivable</span>
                    </div>
                    <p class="text-muted mb-2">Money To Receive</p>
                    <h4 class="mb-0"><%= formatAmount(summary.moneyToReceive) %></h4>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 rounded-0 mb-4">
        <div class="card-body">
            <form action="/reminders" method="get" class="filter-shell">
                <input type="hidden" name="month" value="<%= calendar.monthValue %>">
                <input type="hidden" name="tab" value="<%= filters.tab %>">
                <div class="filter-grid">
                    <div class="filter-field-compact">
                        <label class="form-label fw-medium">Search</label>
                        <input type="text" name="search" class="form-control" value="<%= filters.search %>" placeholder="Search title or person">
                    </div>
                    <div class="filter-field-compact">
                        <label class="form-label fw-medium">Category</label>
                        <select class="form-select" name="category">
                            <option value="">All Categories</option>
                            <option value="emi" <%= filters.category === "emi" ? "selected" : "" %>>EMI</option>
                            <option value="bill" <%= filters.category === "bill" ? "selected" : "" %>>Bill</option>
                            <option value="borrowed" <%= filters.category === "borrowed" ? "selected" : "" %>>Borrowed</option>
                            <option value="lent" <%= filters.category === "lent" ? "selected" : "" %>>Lent</option>
                            <option value="task" <%= filters.category === "task" ? "selected" : "" %>>Task</option>
                        </select>
                    </div>
                    <div class="filter-field-compact">
                        <label class="form-label fw-medium">Status</label>
                        <select class="form-select" name="status">
                            <option value="">All Statuses</option>
                            <option value="upcoming" <%= filters.status === "upcoming" ? "selected" : "" %>>Upcoming</option>
                            <option value="due-today" <%= filters.status === "due-today" ? "selected" : "" %>>Due Today</option>
                            <option value="overdue" <%= filters.status === "overdue" ? "selected" : "" %>>Overdue</option>
                            <option value="paid" <%= filters.status === "paid" ? "selected" : "" %>>Paid</option>
                            <option value="pending" <%= filters.status === "pending" ? "selected" : "" %>>Pending</option>
                            <option value="returned" <%= filters.status === "returned" ? "selected" : "" %>>Returned</option>
                            <option value="received" <%= filters.status === "received" ? "selected" : "" %>>Received</option>
                            <option value="completed" <%= filters.status === "completed" ? "selected" : "" %>>Completed</option>
                        </select>
                    </div>
                    <div class="filter-field-compact">
                        <label class="form-label fw-medium">From Date</label>
                        <input type="date" name="fromDate" class="form-control" value="<%= filters.fromDate %>">
                    </div>
                    <div class="filter-field-compact">
                        <label class="form-label fw-medium">To Date</label>
                        <input type="date" name="toDate" class="form-control" value="<%= filters.toDate %>">
                    </div>
                </div>
                <div class="filter-actions">
                    <button type="submit" class="btn btn-outline-light shadow">Filter</button>
                    <a href="/reminders" class="btn btn-link text-decoration-none p-0">Clear all filters</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-8 d-flex">
            <div class="card calendar-card flex-fill">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
                        <div>
                            <h5 class="mb-1">Monthly Calendar</h5>
                            <p class="text-muted mb-0">Click any date to inspect all reminders and dues scheduled for that day.</p>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <a class="btn btn-icon btn-outline-light shadow" href="/reminders?<%= new URLSearchParams({ search: filters.search, category: filters.category, status: filters.status, fromDate: filters.fromDate, toDate: filters.toDate, month: calendar.prevMonth, tab: filters.tab }).toString() %>">
                                <i class="ti ti-chevron-left"></i>
                            </a>
                            <span class="badge bg-light text-dark px-3 py-2"><%= calendar.monthLabel %></span>
                            <a class="btn btn-icon btn-outline-light shadow" href="/reminders?<%= new URLSearchParams({ search: filters.search, category: filters.category, status: filters.status, fromDate: filters.fromDate, toDate: filters.toDate, month: calendar.nextMonth, tab: filters.tab }).toString() %>">
                                <i class="ti ti-chevron-right"></i>
                            </a>
                        </div>
                    </div>

                    <div class="calendar-grid mb-2">
                        <% dayNames.forEach((day) => { %>
                            <div class="calendar-weekday"><%= day %></div>
                        <% }) %>
                        <% calendar.days.forEach((day) => { %>
                            <% if (day.empty) { %>
                                <div class="calendar-cell empty"></div>
                            <% } else { %>
                                <button
                                    type="button"
                                    class="calendar-cell <%= day.isToday ? "is-today" : "" %> <%= selectedDateKey === day.key ? "active-date" : "" %>"
                                    data-calendar-date="<%= day.key %>">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <span class="calendar-date-number"><%= day.day %></span>
                                        <% if (day.events.length) { %>
                                            <span class="badge bg-light text-dark"><%= day.events.length %></span>
                                        <% } %>
                                    </div>
                                    <div class="calendar-dots">
                                        <% day.events.slice(0, 4).forEach((event) => { %>
                                            <span class="calendar-dot dot-<%= event.colorKey %>"></span>
                                        <% }) %>
                                    </div>
                                </button>
                            <% } %>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 d-flex">
            <div class="day-events-panel p-4 flex-fill">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-3">
                    <div>
                        <h5 class="mb-1">Selected Day</h5>
                        <p class="text-muted mb-0" id="selected-date-label">
                            <%= selectedDateLabelText %>
                        </p>
                    </div>
                    <span class="badge bg-light text-dark" id="selected-date-count">
                        <%= selectedDateKey && calendar.eventsByDate[selectedDateKey] ? calendar.eventsByDate[selectedDateKey].length : 0 %> items
                    </span>
                </div>
                <div id="selected-day-events" class="d-grid gap-3">
                    <% if (selectedDateKey && calendar.eventsByDate[selectedDateKey] && calendar.eventsByDate[selectedDateKey].length) { %>
                        <% calendar.eventsByDate[selectedDateKey].forEach((event) => { %>
                            <div class="event-item">
                                <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                    <div>
                                        <h6 class="mb-1"><%= event.title %></h6>
                                        <div class="text-muted fs-13"><%= event.categoryLabel %></div>
                                    </div>
                                    <span class="calendar-dot dot-<%= event.colorKey %> mt-1"></span>
                                </div>
                                <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                    <span class="badge bg-light text-dark"><%= event.displayStatus %></span>
                                    <% if (event.amount > 0) { %>
                                        <strong><%= formatAmount(event.amount) %></strong>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="event-item text-center text-muted">No reminders on this date yet.</div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <div class="card tab-card mb-4">
        <div class="card-body">
            <div class="tab-row mb-4">
                <div>
                    <div class="section-kicker mb-1">Organized View</div>
                    <h5 class="mb-1">Reminder Tables</h5>
                    <p class="text-muted mb-0">Manage each reminder type with native actions, filters, and edit forms.</p>
                </div>
                <div class="tab-nav">
                    <% tabMeta.forEach((tab) => { %>
                        <a
                            href="/reminders?<%= new URLSearchParams({ search: filters.search, category: filters.category, status: filters.status, fromDate: filters.fromDate, toDate: filters.toDate, month: calendar.monthValue, tab: tab.key }).toString() %>"
                            class="tab-pill text-decoration-none <%= activeTabClass(tab.key) %>">
                            <%= tab.label %> <span class="ms-1 badge <%= filters.tab === tab.key ? "bg-white text-primary" : "bg-light text-dark" %>"><%= tab.count %></span>
                        </a>
                    <% }) %>
                </div>
            </div>

            <div class="table-responsive custom-table table-nowrap">
                <% if (filters.tab === "emi-bills") { %>
                    <table class="table table-nowrap mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Title</th>
                                <th>Amount</th>
